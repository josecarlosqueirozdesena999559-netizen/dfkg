# Server Configuration
PORT=8080
HOST=0.0.0.0
KTOR_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=decisoes
DB_USER=postgres
DB_PASSWORD=postgres

# Firebase Configuration
# Paste full service account JSON contents if using direct env injection
FIREBASE_CREDENTIALS_JSON=
# Or provide absolute path to service-account.json file
FIREBASE_CREDENTIALS_PATH=service-account.json

# Auth Development Bypass (Set to true to skip Firebase signature verification)
# When true, you can send headers like `Authorization: Bearer dev_token_yourusername`
DEV_BYPASS_AUTH=true
